# Frontend environment — copy to frontend/.env and fill in your values.
# (Do NOT commit the real .env.) Vite only exposes variables prefixed with VITE_,
# and they are embedded into the client bundle — never put a secret here.
# Restart `npm run dev` after changing this file; Vite reads it at startup.

# ── Supabase (required) ──────────────────────────────────────────────────────
# Auth runs directly against Supabase from the browser, so the frontend needs these.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ── Google Maps (required for the address picker) ────────────────────────────
# Used by the AddressPicker on Create/Edit Event (which captures the venue's
# latitude/longitude) and by "How to get there" on Event Details. Without it the
# address picker cannot load, so new events get no coordinates and weather checks
# fall back to Singapore-wide instead of the venue's.
# Enable "Maps JavaScript API" + "Places API"; restrict the key by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=your-browser-maps-key

# ── Stripe (card payments; test mode) ────────────────────────────────────────
# Publishable key only — the secret key lives in the backend. Unset = the card form
# is unavailable and purchases must use the in-app wallet.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
