# Backend environment — copy to backend/.env and fill in your values.
# (Do NOT commit the real .env.)
#
# Only SUPABASE_URL + SUPABASE_ANON_KEY are needed to boot. Everything below them is
# feature-gated: leave a key unset and that feature degrades gracefully rather than
# crashing (no Redis → in-memory fallbacks; no Stripe → no card payments; no Gemini →
# no AI; no Resend → no email; no Twilio → phone OTP logs to the console).

# ── Supabase (required) ──────────────────────────────────────────────────────
# Ordinary requests forward each user's JWT and use the ANON / publishable key, so
# Row Level Security stays in force.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# The service-role key BYPASSES RLS. It is used only where there is no signed-in user to
# act as, or where the user must not be trusted: admin moderation, the deadline scheduler,
# Stripe refunds/reconciliation, ticket PDFs, and the phone/password-reset OTP flows.
# Unset it and those paths are disabled; everything else still works.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# NOTE: notificationService also accepts SUPABASE_SERVICE_KEY as an alias, and checks it
# FIRST — set only one, or a stray value here silently wins.
# SUPABASE_SERVICE_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
# API_PORT=8000          # defaults to 8000; PORT is also honoured
# APP_BASE_URL=http://localhost:5173   # FRONTEND origin for links in outgoing emails (set to the deployed frontend URL in prod)
# API_BASE_URL=http://localhost:5173   # BACKEND origin, used only for the ticket-PDF download link (set to the deployed backend URL in prod; defaults to APP_BASE_URL)

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Managed Redis (Upstash / Redis Cloud) for caching, a shared OTP/reset code store, and
# cross-instance rate limiting. Unset = in-memory fallbacks (fine for a single dev process).
# Use the TLS scheme rediss:// (Upstash requires it). The URL itself is the credential.
# REDIS_URL=rediss://default:<password>@<host>:<port>

# ── Stripe (payments; test mode) ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# REFUND_WINDOW_DAYS=180        # refunds older than this are flagged for manual handling
# RECONCILE_LOOKBACK_DAYS=7     # how far back the scheduler scans for orphaned charges
# RECONCILE_MIN_AGE_MINUTES=5   # ignore charges younger than this (a pledge may still be committing)

# ── Email (Resend) ───────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# NOTIFICATION_FROM_EMAIL=party.fun <onboarding@resend.dev>
# NOTIFICATION_OVERRIDE_EMAIL=you@example.com   # dev: send every email here instead

# ── AI (Google Gemini) — enables the whole assistant ─────────────────────────
# GEMINI_API_KEY=...
# AI_GEMINI_MODEL=gemini-2.5-flash        # optional model override
# AI_EMBED_MODEL=gemini-embedding-001     # optional embedding model override

# ── Weather (Google Maps Platform) ───────────────────────────────────────────
# Enable "Weather API" in the same GCP project as Maps. Called server-side only.
# GOOGLE_WEATHER_API_KEY=...

# ── Phone / SMS OTP login (Twilio) ───────────────────────────────────────────
# Unset = mock mode: the code is logged to the backend console instead of sent.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_MESSAGING_SERVICE_SID=MG...
# SMS_OVERRIDE_NUMBER=+65...    # dev: send every SMS to this number instead

# ── Scheduler ────────────────────────────────────────────────────────────────
# DEADLINE_CHECK_INTERVAL_MS=300000   # default 5 min; needs SUPABASE_SERVICE_ROLE_KEY

# ── Integration tests (npm run test:integration) ─────────────────────────────
# TEST_SUPABASE_URL=
# TEST_SUPABASE_SERVICE_ROLE_KEY=
# TEST_SUPABASE_ANON_KEY=
