        <mxCell id="AU_r4" value="raw_user_meta_data  (name, username, role)" style="text;align=left;verticalAlign=middle;spacingLeft=8;fontSize=9;strokeColor=none;fillColor=none;" vertex="1" parent="AU"><mxGeometry y="86" width="270" height="20" as="geometry" /></mxCell>
