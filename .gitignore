# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Local environment files
config.env
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*
# …but the committed templates must survive the rules above (a later rule wins, so these
# negations have to come last — without them .env.example is ignored and never shipped).
!frontend/.env.example
!backend/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime and build output
dist/
frontend/dist/
backend/dist/
build/
frontend/build/
backend/build/
coverage/
frontend/coverage/
backend/coverage/
.cache/
frontend/.cache/
backend/.cache/
.parcel-cache/

# Local tool state
.codex/
.vscode/
.idea/

# MCP config (contains a Supabase personal access token)
.mcp.json

# Local DB schema diagram (generated, not part of the app)
party-fun-db-schema.drawio

# OS files
.DS_Store
Thumbs.db
