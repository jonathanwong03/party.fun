<mxfile host="app.diagrams.net" type="device">
  <diagram id="party-fun-erd-v2" name="party.fun ERD (Supabase Auth + Data)">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== LEGEND / SCENARIO NOTE ===================== -->
        <mxCell id="NOTE" value="Supabase Auth scenario:&#10;• auth.users is created &amp; managed by Supabase Auth (you don't define/edit it).&#10;• On signup, a trigger (handle_new_user) inserts the matching USER profile with USER.id = auth.users.id and role from signup metadata.&#10;• USER has NO passwordHash — credentials live in auth.users.&#10;• All app FKs point at public.USER.id (= the auth UUID).&#10;• Italic = FK, underline = PK." style="text;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;whiteSpace=wrap;rounded=1;fillColor=#fff7e6;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="270" height="150" as="geometry" />
        </mxCell>

        <!-- ===================== AUTH_USERS (Supabase-managed) ===================== -->
        <mxCell id="AU" value="auth.users  (Supabase-managed — you don't create/edit this)" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;resizeParent=1;resizeParentMax=0;collapsible=0;swimlaneFillColor=#ffffff;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="270" height="186" as="geometry" />
        </mxCell>
